# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API (server-only)
SANITY_API_READ_TOKEN=
# Separate browser-safe token for Sanity live preview in draft mode (required)
SANITY_API_BROWSER_TOKEN=
# Secret for enabling draft mode (must NOT be the read token)
SANITY_DRAFT_SECRET=

# Resend (contact form)
RESEND_API_KEY=

# Contact
CONTACT_RECIPIENT_EMAIL=

# Site
NEXT_PUBLIC_SITE_URL=https://tepexidigital.com.mx
